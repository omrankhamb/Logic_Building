import java.util.*;


class program39
{
    public static void main(String Arg[])
    {
        Scanner sobj = new Scanner(System.in);

        int iValue = 0;

        System.out.println("Enter Number : ");
        iValue = sobj.nextInt();
        
        if((iValue % 3 == 0) && (iValue % 5 == 0))
        {
            System.out.println("Number is Divisible by 3 and 5 : "+iValue);
        }else{
            System.out.println("Number is not divisible by 3 and 5 : "+iValue);
        }

        
    }
}
